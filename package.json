{
	"name": "@monolayer/control-plane-sdk",
	"version": "1.0.0-canary.4",
	"type": "module",
	"description": "Control plane SDK and CLI",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"oclif": {
		"bin": "control-plane",
		"commands": "./dist/commands",
		"plugins": [
			"@oclif/plugin-help"
		]
	},
	"bin": {
		"control-plane": "./dist/cli.js"
	},
	"files": [
		"dist/**"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"keywords": [],
	"license": "MIT",
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsdown",
		"postbuild": "npm run alias",
		"alias": "tsc-alias -p tsconfig.alias.json --outDir dist --verbose",
		"check-types": "tsc -p tsconfig.json --noEmit",
		"lint": "eslint .",
		"test": "vitest --run",
		"test:watch": "vitest --watch",
		"publish:local": "npm publish --registry http://localhost:4873",
		"unpublish:local": "npm unpublish --registry http://localhost:4873 @monolayer/control-plane-sdk -f"
	},
