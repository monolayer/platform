{
	"extends": "@repo/typescript-config/base.json",
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022"],
		"types": ["node", "vitest/globals"],
		"noEmit": true,
		"rootDir": ".",
		"plugins": [
			{
				"name": "@effect/language-service"
			}
		]
	},
	"include": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts"],
	"exclude": ["dist", "node_modules", "../../node_modules/**/*"]
}
