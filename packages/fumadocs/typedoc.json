{
  "plugin": [
    "typedoc-plugin-markdown",
    "typedoc-plugin-frontmatter",
    "./lib/custom-frontmatter.mjs"
  ],
  "out": "content/docs/reference/api",
  "entryPoints": [],
  "entryPointStrategy": "expand",
  "tsconfig": "./../sdk/tsconfig.json",
  "exclude": ["**/dist/**/*.ts", "**/vitest.config.ts", "**/test/**/*.ts"],
  "excludeExternals": false,
  "skipErrorChecking": true,
  "enumMembersFormat": "table",
  "groupOrder": ["Workloads", "Testing", "*", "Other"],
  "categoryOrder": ["Workloads", "Testing", "*", "Other"],
  "indexFormat": "list",
  "outputFileStrategy": "members",
  "parametersFormat": "htmlTable",
  "propertiesFormat": "table",
  "useCodeBlocks": true,
  "typeDeclarationFormat": "table",
  "cleanOutputDir": true,
  "navigation": {
    "includeCategories": true,
    "includeGroups": true,
    "includeFolders": true
  },
  "categorizeByGroup": true,
  "expandParameters": false,
  "tableColumnSettings": {
    "hideDefaults": false,
    "hideInherited": true,
    "hideModifiers": false,
    "hideOverrides": true,
    "hideSources": false,
    "hideValues": false,
    "leftAlignHeaders": false
  },
  "disableSources": true
}
