{
	"include": ["**/src/**/*", "**/test/**/*"],
	"compilerOptions": {
		"target": "es2022",
		"lib": ["es2023"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"allowSyntheticDefaultImports": true,
		"stripInternal": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitAny": true,
		"noUncheckedIndexedAccess": true,
		"noUnusedLocals": true,
		"skipLibCheck": true,
		"composite": true,
		"incremental": true,
		"noEmitOnError": true,
		"sourceMap": true,
		"baseUrl": "./",
		"rootDir": ".",
		"paths": {
			"~workloads/*": ["src/*"],
			"~test/*": ["test/*"]
		},
		"outDir": "./dist",
		"emitDeclarationOnly": true,
		"declaration": true,
		"jsx": "react-jsx"
	}
}
