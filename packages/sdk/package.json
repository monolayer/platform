{
  "name": "@monolayer/sdk",
  "version": "2.0.0-canary.1",
  "description": "monolayer SDK",
  "author": "Marcos Essindi <marcessindi@me.com>",
  "license": "MIT",
  "homepage": "https://monolayer.dev/docs/sdk",
  "bugs": "https://github.com/monolayer/sdk/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/monolayer/sdk/",
    "directory": "packages/sdk"
  },
  "keywords": [],
  "bin": {
    "monolayer": "./dist/cli.mjs"
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsdown --config tsdown.config.esm.ts",
    "postbuild": "chmod +x dist/cli.mjs",
    "check-types": "tsgo -p tsconfig.json --noEmit",
    "lint": "oxlint --type-aware",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "publish:local": "npm publish --registry http://localhost:4873",
    "unpublish:local": "npm unpublish --registry http://localhost:4873 @monolayer/sdk -f"
  },
  "dependencies": {
    "@oclif/core": "^4.0.0",
    "@oclif/plugin-help": "^6.2.31",
    "effect": "^3.19.14"
  },
  "devDependencies": {
    "@effect/language-service": "^0.64.1",
    "@types/node": "^22.10.7",
    "@typescript/native-preview": "7.0.0-dev.20260220.1",
    "@vitest/coverage-istanbul": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "oxfmt": "^0.36.0",
    "oxlint-tsgolint": "^0.16.0",
    "oxlint": "^1.51.0",
    "std-env": "4.0.0-rc.1",
    "tsc-alias": "^1.8.16",
    "tsdown": "^0.20.3",
    "type-fest": "^4.10.1",
    "type-testing": "^0.2.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.17"
  },
  "oclif": {
    "bin": "monolayer",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help"
    ]
  }
}
