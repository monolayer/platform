{
  "openapi": "3.0.3",
  "info": {
    "title": "Monolayer CLI API",
    "description": "Programmatic CLI and client API for projects and deployments.",
    "version": "1.0.0",
    "termsOfService": "https://monolayer.com/terms",
    "contact": {
      "name": "Monolayer Support"
    },
    "license": {
      "name": "Proprietary"
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "Current environment"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {}
  },
  "paths": {
    "/cli/projects": {
      "get": {
        "operationId": "cliListProjects",
        "summary": "List projects",
        "description": "Returns a paginated list of projects for authorized CLI clients.",
        "tags": [
          "cli"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "additionalProperties": false,
                    "type": "object",
                    "required": [
                      "id",
                      "createdAt",
                      "name",
                      "repositoryUrl"
                    ],
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "createdAt": {
                        "format": "date-time",
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "repositoryUrl": {
                        "type": "string"
                      }
                    }
                  },
                  "headers": {
                    "Cache-Control": {
                      "const": "private, must-revalidate",
                      "type": "string"
                    },
                    "X-Has-More": {
                      "anyOf": [
                        {
                          "const": "true",
                          "type": "string"
                        },
                        {
                          "const": "false",
                          "type": "string"
                        }
                      ]
                    },
                    "X-Next-Cursor": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Response for status 400",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "const": "Invalid cursor"
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "Response for status 403",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "const": "Forbidden"
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/cli/deployments": {
      "post": {
        "operationId": "cliTriggerDeployment",
        "summary": "Trigger deployment",
        "description": "Triggers or queues a deployment for the authenticated token project.",
        "tags": [
          "cli"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$schema": "https://json-schema.org/draft/2020-12/schema",
                "type": "object",
                "properties": {
                  "branchName": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "branchName"
                ],
                "additionalProperties": false
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$schema": "https://json-schema.org/draft/2020-12/schema",
                "type": "object",
                "properties": {
                  "branchName": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "branchName"
                ],
                "additionalProperties": false
              }
            },
            "multipart/form-data": {
              "schema": {
                "$schema": "https://json-schema.org/draft/2020-12/schema",
                "type": "object",
                "properties": {
                  "branchName": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "branchName"
                ],
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Response for status 202",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "triggered"
                        },
                        "success": {
                          "type": "boolean",
                          "const": true
                        },
                        "deploymentNumber": {
                          "type": "string",
                          "minLength": 1
                        },
                        "queued": {
                          "type": "boolean",
                          "const": false
                        }
                      },
                      "required": [
                        "type",
                        "success",
                        "deploymentNumber",
                        "queued"
                      ],
                      "additionalProperties": false,
                      "title": "SdkTriggerDeploymentTriggeredResponse",
                      "x-stainless-variantName": "triggered"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "queued"
                        },
                        "success": {
                          "type": "boolean",
                          "const": true
                        },
                        "queued": {
                          "type": "boolean",
                          "const": true
                        }
                      },
                      "required": [
                        "type",
                        "success",
                        "queued"
                      ],
                      "additionalProperties": false,
                      "title": "SdkTriggerDeploymentQueuedResponse",
                      "x-stainless-variantName": "queued"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "skipped"
                        },
                        "success": {
                          "type": "boolean",
                          "const": false
                        },
                        "message": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "type",
                        "success",
                        "message"
                      ],
                      "additionalProperties": false,
                      "title": "SdkTriggerDeploymentSkippedResponse",
                      "x-stainless-variantName": "skipped"
                    }
                  ],
                  "title": "SdkTriggerDeploymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Response for status 400",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "const": "CodeBuild project not found"
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "Response for status 403",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "const": "Forbidden"
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "404": {
            "description": "Response for status 404",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "const": "Project not found"
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "502": {
            "description": "Response for status 502",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "const": "Upstream build trigger failed"
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/cli/projects/{projectId}/deployments/{deploymentNumber}": {
      "get": {
        "operationId": "cliGetDeploymentProgress",
        "summary": "Get deployment progress",
        "description": "Returns deployment status and logs for CLI polling clients.",
        "tags": [
          "cli"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "name": "deploymentNumber",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "type": "object",
                  "required": [
                    "status",
                    "logs"
                  ],
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "Queued",
                        "Failed",
                        "Finished",
                        "Ongoing",
                        "Unknown"
                      ]
                    },
                    "logs": {
                      "type": "array",
                      "items": {
                        "additionalProperties": false,
                        "type": "object",
                        "required": [
                          "message",
                          "timestamp",
                          "logGroupName",
                          "logStreamName"
                        ],
                        "properties": {
                          "message": {
                            "type": "string"
                          },
                          "timestamp": {
                            "type": "number"
                          },
                          "ingestionTime": {
                            "type": "number"
                          },
                          "eventId": {
                            "type": "string"
                          },
                          "logGroupName": {
                            "type": "string"
                          },
                          "logStreamName": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  },
                  "headers": {
                    "X-Next-Since": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Response for status 403",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "const": "Forbidden"
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "404": {
            "description": "Response for status 404",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "const": "Deployment not found"
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "502": {
            "description": "Response for status 502",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "const": "Upstream logs fetch failed"
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    }
  }
}